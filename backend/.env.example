# Server
PORT=3001
NODE_ENV=development
FRONTEND_URLS=http://localhost:5173

# PostgreSQL
PGHOST=localhost
PGPORT=5432
PGUSER=snackflow
PGPASSWORD=snackflow_secret
PGDATABASE=snackflow_ai

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# InfluxDB
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=snackflow-token
INFLUX_ORG=snackflow
INFLUX_BUCKET=snackflow_ai

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Translation
GOOGLE_TRANSLATE_API_KEY=
AWS_TRANSLATE_REGION=

# Weather
OPENWEATHER_API_KEY=

# Web Push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@snackflow.ai

# Logging
LOG_LEVEL=info
