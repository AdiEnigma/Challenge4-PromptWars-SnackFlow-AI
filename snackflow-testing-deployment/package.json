{
  "name": "snackflow-testing-deployment",
  "version": "1.0.0",
  "description": "SnackFlow AI Testing Suite and Deployment Configuration",
  "scripts": {
    "test": "jest --config jest.config.js",
    "test:property": "jest --config jest.config.js --testPathPattern=property",
    "test:unit": "jest --config jest.config.js --testPathPattern=unit",
    "test:integration": "jest --config jest.config.js --testPathPattern=integration",
    "test:performance": "jest --config jest.config.js --testPathPattern=performance --timeout=300000",
    "test:all": "npm run test:property && npm run test:unit && npm run test:integration",
    "test:watch": "jest --config jest.config.js --watch",
    "test:coverage": "jest --config jest.config.js --coverage",
    "deploy:dev": "kubectl apply -f kubernetes/dev/",
    "deploy:prod": "kubectl apply -f kubernetes/prod/",
    "build:docker": "docker-compose build",
    "start:local": "docker-compose up -d"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^18.15.0",
    "@types/supertest": "^2.0.12",
    "fast-check": "^3.8.0",
    "jest": "^29.5.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "socket.io-client": "^4.6.1",
    "axios": "^1.3.4"
  }
}