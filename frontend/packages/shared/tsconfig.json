{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "baseUrl": "..",
    "paths": {
      "@snackflow/shared-types": ["shared-types/src"],
      "@snackflow/shared": ["shared/src"]
    }
  },
  "include": ["src"]
}
