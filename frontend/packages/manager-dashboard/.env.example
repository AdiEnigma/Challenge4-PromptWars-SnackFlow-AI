# SnackFlow AI — Manager Dashboard Environment Variables
# Copy this file to .env.local for local development
# Set these as environment variables in your Netlify project settings for production

# Backend API base URL (no trailing slash)
# Local: http://localhost:3001
# Production: https://your-backend.railway.app (or Render/Fly.io)
VITE_API_BASE_URL=http://localhost:3001

# WebSocket server URL (usually same as API base URL)
VITE_WEBSOCKET_URL=http://localhost:3001
